{
    "manifest_version": 3,
    "name": "TLS Slot Monitor",
    "version": "5.0",
    "description": "Мониторинг свободных слотов для записи на приём",
    "permissions": [
        "activeTab",
        "notifications",
        "storage",
        "alarms",
        "scripting",
        "tabs"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icon16.png",
            "48": "icon48.png",
            "128": "icon128.png"
        }
    },
    "background": {
        "service_worker": "background.js"
    },
    "icons": {
        "16": "icon16.png",
        "48": "icon48.png",
        "128": "icon128.png"
    }
}